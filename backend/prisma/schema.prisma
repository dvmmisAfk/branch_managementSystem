generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  supervisor
  sfh
  branch_staff
}

enum BranchType {
  vistaar
  non_vistaar
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum VisitType {
  physical
  virtual
}

enum EditRequestStatus {
  pending
  approved
  rejected
}

enum ScoreStatus {
  yes
  no
  not_applicable
}

enum IssueStatus {
  open
  in_progress
  resolved
}

enum ScoreBand {
  excellent
  good
  satisfactory
  needs_improvement
  critical
}

enum DgOwnership {
  owned
  rented
}

enum SfhPasswordResetRequestStatus {
  pending
  fulfilled
  dismissed
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(255)
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  role             UserRole
  isActive         Boolean   @default(true) @map("is_active")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  stateFacilityHead              StateFacilityHead?
  approvedMappings               SfhBranchMapping[] @relation("MappingApprovedBy")
  auditLogs                      AuditLog[]
  passwordResetTokens            PasswordResetToken[]
  emailVerificationTokens        EmailVerificationToken[]
  sfhPasswordResetRequests       SfhPasswordResetRequest[] @relation("SfhPwdResetUser")
  fulfilledSfhPasswordResets      SfhPasswordResetRequest[] @relation("SfhPwdResetFulfilledBy")
  reviewedEditRequests           VisitEditRequest[]         @relation("EditRequestReviewer")

  @@map("users")
}

model SfhPasswordResetRequest {
  id            String                          @id @default(uuid()) @db.Uuid
  userId        String                          @map("user_id") @db.Uuid
  status        SfhPasswordResetRequestStatus   @default(pending)
  createdAt     DateTime                        @default(now()) @map("created_at")
  fulfilledAt   DateTime?                       @map("fulfilled_at")
  fulfilledById String?                         @map("fulfilled_by_id") @db.Uuid

  user        User  @relation("SfhPwdResetUser", fields: [userId], references: [id], onDelete: Cascade)
  fulfilledBy User? @relation("SfhPwdResetFulfilledBy", fields: [fulfilledById], references: [id])

  @@index([status])
  @@index([userId])
  @@map("sfh_password_reset_requests")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@map("email_verification_tokens")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String   @map("actor_id") @db.Uuid
  action     String   @db.VarChar(160)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model StateFacilityHead {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  employeeCode  String?  @unique @map("employee_code") @db.VarChar(50)
  phone         String?  @db.VarChar(20)
  stateRegion   String?  @map("state_region") @db.VarChar(100)
  /** AES-GCM blob (supervisor-only); updated on create / regenerate / reset fulfill. */
  supervisorPasswordEnc String? @map("supervisor_password_enc")
  createdAt     DateTime @default(now()) @map("created_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mappings     SfhBranchMapping[]
  visits       BranchVisit[]
  editRequests VisitEditRequest[]

  @@map("state_facility_heads")
}

model Branch {
  id                       String       @id @default(uuid()) @db.Uuid
  branchCode               String       @unique @map("branch_code") @db.VarChar(20)
  sapCode                  String?      @map("sap_code") @db.VarChar(20)
  branchName               String       @map("branch_name") @db.VarChar(255)
  location                 String?      @db.VarChar(255)
  city                     String?      @db.VarChar(100)
  state                    String?      @db.VarChar(100)
  zone                     String?      @db.VarChar(100)
  branchType               BranchType   @map("branch_type")
  dateOfOperationalization DateTime?    @map("date_of_operationalization") @db.Date
  carpetAreaSqft           Decimal?     @map("carpet_area_sqft") @db.Decimal(10, 2)
  boiName                  String?      @map("boi_name") @db.VarChar(255)
  branchManagerName        String?      @map("branch_manager_name") @db.VarChar(255)
  branchOperationIncharge  String?      @map("branch_operation_incharge") @db.VarChar(255)
  premiseOwner             String?      @map("premise_owner") @db.VarChar(255)
  staffOutsource           Int          @default(0) @map("staff_outsource")
  staffCompanyRoll         Int          @default(0) @map("staff_company_roll")
  staffHkResources         Int          @default(0) @map("staff_hk_resources")
  staffTalicEmployees      Int          @default(0) @map("staff_talic_employees")
  workstationsLinear       Int          @default(0) @map("workstations_linear")
  workstationsLshape       Int          @default(0) @map("workstations_lshape")
  workstationsCubical      Int          @default(0) @map("workstations_cubical")
  upsCapacityKva           Decimal?     @map("ups_capacity_kva") @db.Decimal(6, 2)
  upsBackupTimeMins        Int?         @map("ups_backup_time_mins")
  acTonnage                Decimal?     @map("ac_tonnage") @db.Decimal(6, 2)
  electricityLoadKw        Decimal?     @map("electricity_load_kw") @db.Decimal(6, 2)
  rmsVendorPresent         Boolean      @default(false) @map("rms_vendor_present")
  rmsVendorName            String?      @map("rms_vendor_name") @db.VarChar(255)
  fireExtinguisherCount    Int          @default(0) @map("fire_extinguisher_count")
  dgOwnership              DgOwnership? @map("dg_ownership")
  dgCapacityKva            Decimal?     @map("dg_capacity_kva") @db.Decimal(6, 2)
  isActive                 Boolean      @default(true) @map("is_active")
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  mappings       SfhBranchMapping[]
  visits         BranchVisit[]
  utilityRecords UtilityConsumption[]

  @@map("branches")
}

model SfhBranchMapping {
  id              String           @id @default(uuid()) @db.Uuid
  sfhId           String           @map("sfh_id") @db.Uuid
  branchId        String           @map("branch_id") @db.Uuid
  approvedById    String?          @map("approved_by") @db.Uuid
  approvalStatus  ApprovalStatus   @default(pending) @map("approval_status")
  approvalRemarks String?          @map("approval_remarks")
  effectiveFrom   DateTime         @map("effective_from") @db.Date
  effectiveTo     DateTime?        @map("effective_to") @db.Date
  isCurrent       Boolean          @default(false) @map("is_current")
  createdAt       DateTime         @default(now()) @map("created_at")

  sfh        StateFacilityHead @relation(fields: [sfhId], references: [id], onDelete: Cascade)
  branch     Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  approvedBy User?             @relation("MappingApprovedBy", fields: [approvedById], references: [id])
  visits     BranchVisit[]

  @@index([sfhId, branchId, isCurrent])
  @@map("sfh_branch_mapping")
}

model Quarter {
  id            String   @id @default(uuid()) @db.Uuid
  financialYear Int      @map("financial_year")
  quarterNumber Int      @map("quarter_number")
  startDate     DateTime @map("start_date") @db.Date
  endDate       DateTime @map("end_date") @db.Date
  label         String?  @db.VarChar(20)

  visits BranchVisit[]

  @@unique([financialYear, quarterNumber])
  @@map("quarters")
}

model AssessmentCategory {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(100)
  displayOrder   Int      @map("display_order")
  weightPercent  Decimal? @map("weight_percent") @db.Decimal(5, 2)
  maxPoints      Int?     @map("max_points")
  version        Int      @default(1)
  effectiveFrom  DateTime @default(now()) @map("effective_from")
  isActive       Boolean  @default(true) @map("is_active")

  subcategories AssessmentSubcategory[]
  visitIssues VisitIssue[]

  @@map("assessment_categories")
}

model AssessmentSubcategory {
  id                   String   @id @default(uuid()) @db.Uuid
  categoryId           String   @map("category_id") @db.Uuid
  name                 String
  description          String?
  maxScore             Int      @default(5) @map("max_score")
  weightWithinCategory Decimal? @map("weight_within_category") @db.Decimal(5, 2)
  displayOrder         Int      @map("display_order")
  isActive             Boolean  @default(true) @map("is_active")

  category    AssessmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  visitScores VisitScore[]

  @@unique([categoryId, displayOrder])
  @@map("assessment_subcategories")
}

model BranchVisit {
  id                           String     @id @default(uuid()) @db.Uuid
  branchId                     String     @map("branch_id") @db.Uuid
  sfhId                        String     @map("sfh_id") @db.Uuid
  quarterId                    String     @map("quarter_id") @db.Uuid
  mappingId                    String?    @map("mapping_id") @db.Uuid
  visitDateActual              DateTime?  @map("visit_date_actual") @db.Date
  visitDateLockedAt            DateTime?  @map("visit_date_locked_at")
  previousVisitDate            DateTime?  @map("previous_visit_date") @db.Date
  previousVisitScore           Decimal?   @map("previous_visit_score") @db.Decimal(5, 2)
  visitType                    VisitType  @map("visit_type")
  virtualStaffContactName      String?    @map("virtual_staff_contact_name") @db.VarChar(255)
  virtualStaffContactPhone     String?    @map("virtual_staff_contact_phone") @db.VarChar(20)
  reasonForNoVisit             String?    @map("reason_for_no_visit")
  boiNameSnapshot              String?    @map("boi_name_snapshot") @db.VarChar(255)
  locationHeadSnapshot         String?    @map("location_head_snapshot") @db.VarChar(255)
  staffOutsourceSnapshot       Int?       @map("staff_outsource_snapshot")
  staffCompanySnapshot         Int?       @map("staff_company_snapshot")
  staffHkResourcesSnapshot     Int?       @map("staff_hk_resources_snapshot")
  staffTalicEmployeesSnapshot  Int?       @map("staff_talic_employees_snapshot")
  workstationsLinearSnapshot   Int?       @map("workstations_linear_snapshot")
  workstationsLshapeSnapshot   Int?       @map("workstations_lshape_snapshot")
  workstationsCubicalSnapshot  Int?       @map("workstations_cubical_snapshot")
  isInfraUpgrade               Boolean    @default(false) @map("is_infra_upgrade")
  landlordIssue                Boolean    @default(false) @map("landlord_issue")
  landlordIssueDetails         String?    @map("landlord_issue_details")
  incidentPreviousVisit        Boolean    @default(false) @map("incident_previous_visit")
  incidentPreviousVisitDetails String?    @map("incident_previous_visit_details")
  auditPointsObserved          Boolean    @default(false) @map("audit_points_observed")
  auditPointsDetails           String?    @map("audit_points_details")
  majorEscalation              Boolean    @default(false) @map("major_escalation")
  escalationDetails            String?    @map("escalation_details")
  escalationClosureDate        DateTime?  @map("escalation_closure_date") @db.Date
  electricityLastQuarter       Decimal?   @map("electricity_last_quarter") @db.Decimal(12, 2)
  utilityLinesJson             Json?      @map("utility_lines_json")
  isSubmitted                  Boolean    @default(false) @map("is_submitted")
  submittedAt                  DateTime?  @map("submitted_at")
  signedSfhAt                  DateTime?  @map("signed_sfh_at")
  signedOpsInchargeAt          DateTime?  @map("signed_ops_incharge_at")
  signedLocationHeadAt        DateTime?  @map("signed_location_head_at")
  createdAt                    DateTime   @default(now()) @map("created_at")
  updatedAt                    DateTime   @updatedAt @map("updated_at")

  branch  Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sfh     StateFacilityHead @relation(fields: [sfhId], references: [id], onDelete: Cascade)
  quarter Quarter           @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  mapping SfhBranchMapping? @relation(fields: [mappingId], references: [id])

  scores        VisitScore[]
  issues        VisitIssue[]
  scoreSnapshot ScoreSnapshot?
  editRequests  VisitEditRequest[]

  @@unique([branchId, quarterId])
  @@index([sfhId, isSubmitted])
  @@index([quarterId])
  @@map("branch_visits")
}

model VisitScore {
  id             String       @id @default(uuid()) @db.Uuid
  visitId        String       @map("visit_id") @db.Uuid
  subcategoryId  String       @map("subcategory_id") @db.Uuid
  status         ScoreStatus
  scoreGiven     Int?         @map("score_given")
  maxScore       Int          @map("max_score")
  observations   String?
  remsNumber     String?      @map("rems_number") @db.VarChar(100)
  remarks        String?

  visit       BranchVisit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  subcategory AssessmentSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  @@unique([visitId, subcategoryId])
  @@map("visit_scores")
}

model VisitIssue {
  id                   String      @id @default(uuid()) @db.Uuid
  visitId              String      @map("visit_id") @db.Uuid
  categoryId           String      @map("category_id") @db.Uuid
  issueDescription     String      @map("issue_description")
  scheduledClosureDate DateTime?   @map("scheduled_closure_date") @db.Date
  issueStatus          IssueStatus @default(open) @map("issue_status")
  resolutionNotes      String?     @map("resolution_notes")
  createdAt            DateTime    @default(now()) @map("created_at")
  resolvedAt           DateTime?   @map("resolved_at")

  visit    BranchVisit          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  category AssessmentCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@map("visit_issues")
}

model ScoreSnapshot {
  id                String    @id @default(uuid()) @db.Uuid
  visitId           String    @unique @map("visit_id") @db.Uuid
  totalPointsEarned Int       @map("total_points_earned")
  totalMaxPoints    Int       @map("total_max_points")
  scorePercentage   Decimal   @map("score_percentage") @db.Decimal(5, 2)
  scoreBand         ScoreBand @map("score_band")
  categoryBreakdown Json      @map("category_breakdown")
  calculatedAt      DateTime  @default(now()) @map("calculated_at")

  visit BranchVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("score_snapshots")
}

model UtilityConsumption {
  id                   String    @id @default(uuid()) @db.Uuid
  branchId             String    @map("branch_id") @db.Uuid
  financialYear        Int       @map("financial_year")
  quarterNumber        Int       @map("quarter_number")
  electricityBillAmount Decimal? @map("electricity_bill_amount") @db.Decimal(12, 2)
  unitsConsumed        Decimal?  @map("units_consumed") @db.Decimal(10, 2)
  otExpenses           Decimal?  @map("ot_expenses") @db.Decimal(12, 2)
  actionPointsExpenses String?   @map("action_points_expenses")
  remarks              String?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, financialYear, quarterNumber])
  @@map("utility_consumption")
}

model VisitEditRequest {
  id           String            @id @default(uuid()) @db.Uuid
  visitId      String            @map("visit_id") @db.Uuid
  sfhId        String            @map("sfh_id") @db.Uuid
  reason       String
  status       EditRequestStatus @default(pending)
  reviewedById String?           @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?         @map("reviewed_at")
  createdAt    DateTime          @default(now()) @map("created_at")

  visit      BranchVisit       @relation(fields: [visitId], references: [id], onDelete: Cascade)
  sfh        StateFacilityHead @relation(fields: [sfhId], references: [id], onDelete: Cascade)
  reviewedBy User?             @relation("EditRequestReviewer", fields: [reviewedById], references: [id])

  @@index([visitId])
  @@index([status])
  @@map("visit_edit_requests")
}
