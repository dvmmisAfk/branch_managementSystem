# Copy to .env on the server. Never commit real secrets.
# Generate each secret individually: openssl rand -base64 48

NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# JWT signing secret — used exclusively for signing/verifying access tokens.
JWT_SECRET=replace-with-at-least-32-random-bytes-hex-or-base64

# JWT refresh-token signing secret — separate from JWT_SECRET.
JWT_REFRESH_SECRET=replace-with-a-different-32-plus-char-secret

# F-02: AES key-derivation secret for the SFH supervisor-password vault.
# MUST differ from JWT_SECRET — they serve different cryptographic purposes.
VAULT_SECRET=replace-with-another-distinct-32-plus-char-secret

JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

PORT=3001

# Comma-separated browser origins — REQUIRED when NODE_ENV=production (enforced at startup).
# Set this to the exact Vercel URL after first deploy (see F-06 in SECURITY_AUDIT.md).
ALLOWED_ORIGINS=https://your-frontend.example.com

# Optional: HTTPS host suffixes for preview deploys (e.g. .vercel.app).
# WARNING: bare public suffixes like .vercel.app are overly broad — restrict to the
# specific Vercel project prefix once the production URL is known (see F-06).
# ALLOWED_ORIGIN_SUFFIXES=.vercel.app

# Cross-site cookies when frontend and API are on different hosts (Vercel + Render). Use lax for same-origin Docker/nginx.
COOKIE_SAME_SITE=none

# Production defaults to enforcing HTTPS via X-Forwarded-Proto (set to false only if you know why).
# ENFORCE_HTTPS=true

# Set false on the server unless you are actively debugging (avoids leaking stacks in JSON errors).
API_DEBUG=false

# F-05: Optional Redis URL for persistent, distributed rate limiting across container restarts
# and horizontal instances. Falls back to per-process MemoryStore when unset (logged at startup).
# REDIS_URL=redis://localhost:6379

# F-14: bcrypt cost factor (10–14). Validated at startup; values outside range are rejected.
# BCRYPT_ROUNDS=12

# Optional: set true only if you enforce verified emails in the product.
# REQUIRE_EMAIL_VERIFICATION=false

# Optional: public web app URL for future email flows.
# APP_PUBLIC_URL=https://your-app.example.com

# --- Local seed only (npm run db:seed); not needed on a running API container unless you seed there.
# SEED_SUPERVISOR_EMAIL=supervisor@example.com
# SEED_SUPERVISOR_PASSWORD=at-least-8-chars
