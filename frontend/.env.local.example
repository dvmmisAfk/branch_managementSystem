# Copy to `.env.local` (gitignored). Do not commit real secrets.
#
# This app uses the Express API only — do NOT set Supabase anon keys here.
# Supabase is used as managed Postgres (DATABASE_URL on the backend).

# Optional: override API base URL for local dev (Vite proxy default is /api/v1).
# VITE_API_BASE_URL=http://127.0.0.1:3001/api/v1
