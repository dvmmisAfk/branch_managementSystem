# Used at `npm run build` / Docker build. Copy to .env.production or pass build args.

# Full URL prefix for API (no trailing slash). Must match how nginx or the host exposes /api/v1.
VITE_API_BASE_URL=https://your-api-host.example.com/api/v1

# Optional — Supabase JS client (`src/lib/supabaseBrowser.ts`). Leave unset if unused.
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Set true only when you need browser-readable source maps for debugging a production build.
# VITE_DEBUG=false
