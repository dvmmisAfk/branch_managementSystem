# Used at `npm run build` / Docker build. Copy to .env.production or pass build args.

# Same-origin API via Vercel middleware proxy (recommended for custom domains):
VITE_API_BASE_URL=/api/v1

# Server-side only — Vercel Edge middleware proxies /api/v1 to this host (no trailing slash):
# BACKEND_API_ORIGIN=https://branch-visit-api.onrender.com

# Alternative: call Render directly (requires ALLOWED_ORIGINS on Render to match your Vercel/custom domain):
# VITE_API_BASE_URL=https://branch-visit-api.onrender.com/api/v1

# Do NOT set VITE_SUPABASE_URL or VITE_SUPABASE_ANON_KEY — the frontend talks to the Express API only.

# Set true only when you need browser-readable source maps for debugging a production build.
# VITE_DEBUG=false
